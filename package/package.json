{
  "name": "@snhaman/pollymorph",
  "version": "1.6.0",
  "description": "Elucidata unified design system — tokens, rules, component specs, types, CSS variables, and icons",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./css": "./dist/pollymorph.css",
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.mjs",
      "require": "./dist/tokens.js"
    },
    "./rules": {
      "types": "./dist/rules.d.ts",
      "import": "./dist/rules.mjs",
      "require": "./dist/rules.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.mjs",
      "require": "./dist/icons.js"
    },
    "./fonts": "./dist/pds-icons.css",
    "./react-icons": {
      "types": "./dist/react-icons.d.ts",
      "import": "./dist/react-icons.mjs",
      "require": "./dist/react-icons.js"
    },
    "./svg": {
      "types": "./dist/svg.d.ts",
      "import": "./dist/svg.mjs",
      "require": "./dist/svg.js"
    }
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "design-tokens",
    "elucidata",
    "polly",
    "design-system",
    "pollymorph"
  ],
  "author": "Elucidata",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}